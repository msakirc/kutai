{
  "service_name": "stripe",
  "required_fields": ["secret_key", "publishable_key"],
  "optional_fields": ["webhook_secret", "tax_origin_country", "account_id"],
  "scopes": ["read_only", "read_write", "admin"],
  "default_scope": "read_write",
  "rotation_recommended_days": 90,
  "test_endpoint": { "action": "retrieve_balance", "expect_status": 200 },
  "docs_url": "https://stripe.com/docs/keys"
}
