{
  "plan_id": "shopping_v3",
  "version": "3.0",
  "metadata": {
    "description": "v3 category/discovery shopping. Same pipeline as v2 but every LLM call is an admitted agent:<producer> step (no inline request()/await_inline) — grouping/labeling/synthesis run as shopping_grouper/shopping_labeler/shopping_synthesizer producer agents between deterministic prep/apply steps. Unblocks CPS SP5.",
    "agents_required": ["shopping_pipeline_v2", "shopping_clarifier", "shopping_grouper", "shopping_labeler", "shopping_synthesizer", "mechanical"],
    "performance_target": {"max_duration_seconds": 180, "escalation_trigger": "no_products_found"},
    "timeout_hours": 2
  },
  "phases": [
    {"id": "phase_0", "name": "Understand query", "goal": "Parse intent, clarify if vague.", "depends_on_phases": []},
    {"id": "phase_1", "name": "Resolve candidates", "goal": "Fetch top-N per site.", "depends_on_phases": ["phase_0"]},
    {"id": "phase_2", "name": "Gate & branch", "goal": "Group/label/gate + producer-agent synth paths.", "depends_on_phases": ["phase_1"]},
    {"id": "phase_3", "name": "Format & deliver", "goal": "Render cards.", "depends_on_phases": ["phase_2"]}
  ],
  "steps": [
    {
      "id": "0.1", "phase": "phase_0", "name": "understand_query_check_clarity",
      "title": "Understand Query", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": [],
      "input_artifacts": ["user_query"],
      "output_artifacts": ["parsed_intent"],
      "instruction": "Step name: understand_query_check_clarity. Parse the user's query — intent, category, constraints, vagueness check. Sets needs_clarification flag for step 0.2.",
      "done_when": "parsed_intent has query and needs_clarification fields.",
      "artifact_schema": {"max_output_chars": 5000, "parsed_intent": {"type": "object", "required_fields": ["query", "needs_clarification"]}}
    },
    {
      "id": "0.2", "phase": "phase_0", "name": "ask_clarifying_questions",
      "title": "Clarify If Vague", "agent": "shopping_clarifier",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["0.1"],
      "input_artifacts": ["parsed_intent", "user_query"],
      "output_artifacts": ["clarified_query"],
      "instruction": "Read parsed_intent and user_query. If needs_clarification is true and constraints are absent, ask 2-3 tight questions (budget? use case? must-have feature?). If query has enough detail, return it as clarified_query immediately.",
      "done_when": "clarified_query is ready for search — either the original query or the user's answers incorporated.",
      "may_need_clarification": true
    },
    {
      "id": "1.0", "phase": "phase_1", "name": "resolve_candidates",
      "title": "Resolve Candidates", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["0.2"],
      "input_artifacts": ["clarified_query"],
      "output_artifacts": ["search_results"],
      "instruction": "Step name: resolve_candidates. Top-8 per site for wider category sweep.",
      "done_when": "search_results.candidates populated.",
      "context": {"per_site_n": 8}
    },
    {
      "id": "1.1a", "phase": "phase_2", "name": "group_prep",
      "title": "Group Prep (SKU bucket + residual view)", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["1.0"],
      "input_artifacts": ["search_results"],
      "output_artifacts": ["group_input", "groups_state"],
      "instruction": "Step name: group_prep.",
      "done_when": "group_input.has_residuals set; groups_state carries bucketed groups.",
      "context": {"requires_grading": false}
    },
    {
      "id": "1.1b", "phase": "phase_2", "name": "group_dispatch",
      "title": "Group Residuals (LLM)", "agent": "shopping_grouper",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["1.1a"],
      "input_artifacts": ["group_input"],
      "output_artifacts": ["group_raw"],
      "instruction": "Cluster the residual candidate listings in the input artifact into same-product groups. Return ONLY the JSON described by your schema.",
      "done_when": "group_raw is a JSON object with a groups array.",
      "skip_when": "group_input.has_residuals == 'false'",
      "context": {"requires_grading": false}
    },
    {
      "id": "1.1c", "phase": "phase_2", "name": "group_apply_label_prep",
      "title": "Apply Grouping + Label Prep", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["1.1b"],
      "input_artifacts": ["group_raw", "groups_state"],
      "output_artifacts": ["label_input", "groups_state"],
      "instruction": "Step name: group_apply_label_prep.",
      "done_when": "label_input.view populated; groups_state merged.",
      "context": {"requires_grading": false}
    },
    {
      "id": "1.1d", "phase": "phase_2", "name": "label_dispatch",
      "title": "Label Groups (LLM)", "agent": "shopping_labeler",
      "difficulty": "medium", "tools_hint": [], "depends_on": ["1.1c"],
      "input_artifacts": ["label_input"],
      "output_artifacts": ["label_raw"],
      "instruction": "Tag every product group in the input artifact with line_id/base_model/variant/product_type taxonomy. Return ONLY the JSON described by your schema.",
      "done_when": "label_raw is a JSON object with a groups array.",
      "context": {"requires_grading": false}
    },
    {
      "id": "1.1e", "phase": "phase_2", "name": "label_apply_filter_gate",
      "title": "Apply Labels + Filter + Gate", "agent": "shopping_pipeline_v2",
      "difficulty": "medium", "tools_hint": [], "depends_on": ["1.1d"],
      "input_artifacts": ["label_raw", "groups_state"],
      "output_artifacts": ["gate_result"],
      "instruction": "Step name: label_apply_filter_gate.",
      "done_when": "gate_result.gate.kind is chosen|clarify|escalation.",
      "context": {"requires_grading": false}
    },
    {
      "id": "2.0a", "phase": "phase_2", "name": "synth_prep",
      "title": "Synth Prep (chosen path)", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["1.1e"],
      "input_artifacts": ["gate_result"],
      "output_artifacts": ["synth_input", "synth_meta"],
      "instruction": "Step name: synth_prep.",
      "done_when": "synth_input + synth_meta emitted.",
      "skip_when": "gate_result.gate.kind != 'chosen'",
      "context": {"requires_grading": false}
    },
    {
      "id": "2.0b", "phase": "phase_2", "name": "synth_dispatch",
      "title": "Synthesise Reviews (chosen, LLM)", "agent": "shopping_synthesizer",
      "difficulty": "hard", "tools_hint": [], "depends_on": ["2.0a"],
      "input_artifacts": ["synth_input"],
      "output_artifacts": ["synth_raw"],
      "instruction": "Synthesise the review snippets in the input artifact into aspect-level insights for the product. Return ONLY the JSON described by your schema.",
      "done_when": "synth_raw is a JSON object.",
      "skip_when": "gate_result.gate.kind != 'chosen'",
      "context": {"requires_grading": false}
    },
    {
      "id": "2.0c", "phase": "phase_2", "name": "synth_apply",
      "title": "Render Card (chosen)", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["2.0b"],
      "input_artifacts": ["synth_raw", "synth_meta"],
      "output_artifacts": ["synth_result"],
      "instruction": "Step name: synth_apply.",
      "done_when": "synth_result.cards populated.",
      "skip_when": "gate_result.gate.kind != 'chosen'",
      "context": {"requires_grading": false}
    },
    {
      "id": "2.1", "phase": "phase_2", "name": "clarify_variant",
      "title": "Clarify Variant Choice", "agent": "mechanical",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["1.1e"],
      "input_artifacts": ["gate_result"],
      "output_artifacts": ["clarify_choice"],
      "instruction": "Mechanical: clarify (variant_choice).",
      "done_when": "clarify_choice populated by user tap.",
      "skip_when": "gate_result.gate.kind != 'clarify'",
      "context": {"executor": "clarify", "payload_from": "gate_result", "kind": "variant_choice", "requires_grading": false}
    },
    {
      "id": "2.2a", "phase": "phase_2", "name": "synth_prep",
      "title": "Synth Prep (after variant pick)", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["2.1"],
      "input_artifacts": ["clarify_choice", "gate_result"],
      "output_artifacts": ["synth_input", "synth_meta"],
      "instruction": "Step name: synth_prep.",
      "done_when": "synth_input + synth_meta emitted.",
      "skip_when": "clarify_choice.kind != 'variant'",
      "context": {"requires_grading": false}
    },
    {
      "id": "2.2b", "phase": "phase_2", "name": "synth_dispatch",
      "title": "Synthesise Reviews (variant, LLM)", "agent": "shopping_synthesizer",
      "difficulty": "hard", "tools_hint": [], "depends_on": ["2.2a"],
      "input_artifacts": ["synth_input"],
      "output_artifacts": ["synth_raw"],
      "instruction": "Synthesise the review snippets in the input artifact into aspect-level insights for the product. Return ONLY the JSON described by your schema.",
      "done_when": "synth_raw is a JSON object.",
      "skip_when": "clarify_choice.kind != 'variant'",
      "context": {"requires_grading": false}
    },
    {
      "id": "2.2c", "phase": "phase_2", "name": "synth_apply",
      "title": "Render Card (variant)", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["2.2b"],
      "input_artifacts": ["synth_raw", "synth_meta"],
      "output_artifacts": ["synth_result"],
      "instruction": "Step name: synth_apply.",
      "done_when": "synth_result.cards populated.",
      "skip_when": "clarify_choice.kind != 'variant'",
      "context": {"requires_grading": false}
    },
    {
      "id": "3.0", "phase": "phase_3", "name": "format_response",
      "title": "Format & Deliver Response", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["2.0c", "2.2c"],
      "input_artifacts": ["synth_result"],
      "output_artifacts": ["shopping_response"],
      "instruction": "Step name: format_response.",
      "done_when": "shopping_response.formatted_text populated.",
      "skip_when": "synth_result.cards is empty",
      "context": {"requires_grading": false}
    }
  ]
}
