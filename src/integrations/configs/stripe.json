{
  "service_name": "stripe",
  "base_url": "https://api.stripe.com",
  "auth_type": "bearer",
  "auth_header": "Authorization",
  "auth_token_field": "secret_key",
  "actions": {
    "list_products": {
      "method": "GET",
      "path": "/v1/products",
      "required_params": []
    },
    "create_product": {
      "method": "POST",
      "path": "/v1/products",
      "required_params": ["name"]
    },
    "create_price": {
      "method": "POST",
      "path": "/v1/prices",
      "required_params": ["unit_amount", "currency", "product"]
    },
    "create_checkout_session": {
      "method": "POST",
      "path": "/v1/checkout/sessions",
      "required_params": ["mode", "success_url"]
    },
    "list_subscriptions": {
      "method": "GET",
      "path": "/v1/subscriptions",
      "required_params": []
    },
    "retrieve_balance": {
      "method": "GET",
      "path": "/v1/balance",
      "required_params": []
    }
  }
}
