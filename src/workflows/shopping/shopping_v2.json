{
  "plan_id": "shopping_v2",
  "version": "2.0",
  "metadata": {
    "description": "v2 category/discovery shopping. Clarifies vague queries, fetches top-8 per site, LLM groups into product tiers, synthesises reviews for top 3 tiers, renders reviews-first cards.",
    "agents_required": ["shopping_pipeline_v2"],
    "performance_target": {"max_duration_seconds": 180, "escalation_trigger": "no_products_found"},
    "timeout_hours": 2
  },
  "phases": [
    {"id": "phase_0", "name": "Understand query", "goal": "Parse intent, clarify if vague.", "depends_on_phases": []},
    {"id": "phase_1", "name": "Resolve candidates", "goal": "Fetch top-N per site.", "depends_on_phases": ["phase_0"]},
    {"id": "phase_2", "name": "Gate & branch", "goal": "Variant gate decision + parallel synth/clarify paths.", "depends_on_phases": ["phase_1"]},
    {"id": "phase_3", "name": "Format & deliver", "goal": "Render cards.", "depends_on_phases": ["phase_2"]}
  ],
  "steps": [
    {
      "id": "0.1", "phase": "phase_0", "name": "understand_query_check_clarity",
      "title": "Understand Query", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": [],
      "input_artifacts": ["user_query"],
      "output_artifacts": ["parsed_intent"],
      "instruction": "Parse the user's query — intent, category, constraints, vagueness check. Sets needs_clarification flag for step 0.2.",
      "done_when": "parsed_intent has query and needs_clarification fields.",
      "artifact_schema": {"max_output_chars": 5000, "parsed_intent": {"type": "object", "required_fields": ["query", "needs_clarification"]}}
    },
    {
      "id": "0.2", "phase": "phase_0", "name": "ask_clarifying_questions",
      "title": "Clarify If Vague", "agent": "shopping_clarifier",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["0.1"],
      "input_artifacts": ["parsed_intent", "user_query"],
      "output_artifacts": ["clarified_query"],
      "instruction": "Read parsed_intent and user_query. If needs_clarification is true and constraints are absent, ask 2-3 tight questions (budget? use case? must-have feature?). If query has enough detail, return it as clarified_query immediately.",
      "done_when": "clarified_query is ready for search — either the original query or the user's answers incorporated.",
      "may_need_clarification": true
    },
    {
      "id": "1.0", "phase": "phase_1", "name": "resolve_candidates",
      "title": "Resolve Candidates", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["0.2"],
      "input_artifacts": ["clarified_query"],
      "output_artifacts": ["search_results"],
      "instruction": "Step name: resolve_candidates. Top-8 per site for wider category sweep.",
      "done_when": "search_results.candidates populated.",
      "context": {"per_site_n": 8}
    },
    {
      "id": "1.1", "phase": "phase_2", "name": "group_label_filter_gate",
      "title": "Group Label Filter Gate", "agent": "shopping_pipeline_v2",
      "difficulty": "medium", "tools_hint": [], "depends_on": ["1.0"],
      "input_artifacts": ["search_results"],
      "output_artifacts": ["gate_result"],
      "instruction": "Step name: group_label_filter_gate.",
      "done_when": "gate_result.gate.kind is chosen|clarify|escalation."
    },
    {
      "id": "2.0", "phase": "phase_2", "name": "synth_one",
      "title": "Synthesise (chosen path)", "agent": "shopping_pipeline_v2",
      "difficulty": "medium", "tools_hint": [], "depends_on": ["1.1"],
      "input_artifacts": ["gate_result"],
      "output_artifacts": ["synth_result"],
      "skip_when": "gate_result.gate.kind != 'chosen'"
    },
    {
      "id": "2.1", "phase": "phase_2", "name": "clarify_variant",
      "title": "Clarify Variant Choice", "agent": "mechanical",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["1.1"],
      "input_artifacts": ["gate_result"],
      "output_artifacts": ["clarify_choice"],
      "instruction": "Mechanical: clarify (variant_choice).",
      "done_when": "clarify_choice populated by user tap.",
      "skip_when": "gate_result.gate.kind != 'clarify'",
      "context": {"executor": "clarify", "payload_from": "gate_result", "kind": "variant_choice", "requires_grading": false}
    },
    {
      "id": "2.2", "phase": "phase_2", "name": "synth_one",
      "title": "Synthesise After Variant Choice", "agent": "shopping_pipeline_v2",
      "difficulty": "medium", "tools_hint": [], "depends_on": ["2.1"],
      "input_artifacts": ["clarify_choice", "gate_result"],
      "output_artifacts": ["synth_result"],
      "skip_when": "clarify_choice.kind != 'variant'"
    },
    {
      "id": "2.3", "phase": "phase_2", "name": "format_compare",
      "title": "Format Compare-All", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["2.1"],
      "input_artifacts": ["clarify_choice", "gate_result"],
      "output_artifacts": ["shopping_response"],
      "skip_when": "clarify_choice.kind != 'compare_all'",
      "context": {"requires_grading": false}
    },
    {
      "id": "3.0", "phase": "phase_3", "name": "format_response",
      "title": "Format & Deliver Response", "agent": "shopping_pipeline_v2",
      "difficulty": "easy", "tools_hint": [], "depends_on": ["2.0", "2.2", "2.3"],
      "input_artifacts": ["synth_result"],
      "output_artifacts": ["shopping_response"],
      "instruction": "Step name: format_response.",
      "done_when": "shopping_response.formatted_text populated.",
      "skip_when": "synth_result.cards is empty",
      "context": {"requires_grading": false}
    }
  ]
}
