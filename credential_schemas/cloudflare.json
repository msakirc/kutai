{
  "service_name": "cloudflare",
  "required_fields": ["api_token"],
  "optional_fields": ["account_id", "zone_id"],
  "scopes": ["read_only", "read_write", "admin"],
  "default_scope": "read_write",
  "rotation_recommended_days": 90,
  "test_endpoint": { "action": "list_zones", "expect_status": 200 },
  "docs_url": "https://developers.cloudflare.com/fundamentals/api/get-started/create-token/"
}
