{
  "service_name": "sentry",
  "base_url": "https://sentry.io/api/0",
  "auth_type": "bearer",
  "auth_header": "Authorization",
  "auth_token_field": "auth_token",
  "actions": {
    "list_projects": {
      "method": "GET",
      "path": "/projects/",
      "required_params": []
    },
    "list_issues": {
      "method": "GET",
      "path": "/projects/{org}/{project}/issues/",
      "required_params": ["org", "project"]
    },
    "get_issue": {
      "method": "GET",
      "path": "/issues/{issue_id}/",
      "required_params": ["issue_id"]
    },
    "list_releases": {
      "method": "GET",
      "path": "/organizations/{org}/releases/",
      "required_params": ["org"]
    }
  }
}
